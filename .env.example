# ── AI Provider Config ─────────────────────────────────────────────────────────
# Choose ONE of the configs below and fill in your API key.

# === Option 1: Anthropic (default) ===
ANTHROPIC_API_KEY=your_anthropic_key_here
# AI_PROVIDER=anthropic

# === Option 2: SumoPod (OpenAI-compatible, multi-model) ===
# AI_PROVIDER=sumopod
# AI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxx
# AI_BASE_URL=https://ai.sumopod.com/v1
# AI_SMART_MODEL=gpt-4o
# AI_FAST_MODEL=seed-2-0-mini-free

# === Option 3: OpenAI ===
# AI_PROVIDER=openai
# AI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxx

# === Option 4: DeepSeek ===
# AI_PROVIDER=deepseek
# AI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxx

# === Option 5: Groq (free tier available) ===
# AI_PROVIDER=groq
# AI_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxx

# === Option 6: Gemini (Google) ===
# AI_PROVIDER=gemini
# AI_API_KEY=AIzaSyxxxxxxxxxxxxxx

# === Option 7: Grok (xAI) ===
# AI_PROVIDER=grok
# AI_API_KEY=xai-xxxxxxxxxxxxxxxxxxxx

# === Option 8: Qwen (Alibaba) ===
# AI_PROVIDER=qwen
# AI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxx

# === Option 9: BytePlus / Seed ===
# AI_PROVIDER=byteplus
# AI_API_KEY=xxxxxxxxxxxxxxxxxxxx
# AI_SMART_MODEL=seed-2-0
# AI_FAST_MODEL=seed-2-0-mini-free

# === Option 10: Custom (any OpenAI-compatible) ===
# AI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxx
# AI_BASE_URL=https://your-provider.com/v1
# AI_SMART_MODEL=your-smart-model
# AI_FAST_MODEL=your-fast-model
