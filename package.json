{
  "name": "try33x",
  "version": "1.0.0",
  "description": "AI-powered YouTube Short clipper CLI — auto-clip, subtitle, and caption videos with one command",
  "author": "Fikri",
  "license": "MIT",
  "keywords": [
    "youtube",
    "shorts",
    "clipper",
    "subtitle",
    "caption",
    "ffmpeg",
    "yt-dlp",
    "ai",
    "cli",
    "video"
  ],
  "homepage": "https://github.com/fikrinurhakim/try33x",
  "repository": {
    "type": "git",
    "url": "https://github.com/fikrinurhakim/try33x.git"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "files": [
    "dist"
  ],
  "bin": {
    "try33x": "./dist/main.js"
  },
  "type": "module",
  "scripts": {
    "dev": "bun src/main.tsx",
    "build": "bun build src/main.tsx --outdir dist --target node --sourcemap=none --packages=external && chmod +x dist/main.js",
    "start": "node dist/main.js",
    "install:global": "bun run build && npm link",
    "test-caption": "bun src/test-caption.ts",
    "prepublishOnly": "bun run build"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.36.0",
    "commander": "^12.0.0",
    "fluent-ffmpeg": "^2.1.3",
    "ink": "^5.0.1",
    "ink-spinner": "^5.0.0",
    "openai": "^6.33.0",
    "react": "^18.3.1",
    "yt-dlp-exec": "^1.0.2",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/fluent-ffmpeg": "^2.1.27",
    "@types/node": "^22.0.0",
    "@types/react": "^18.3.1",
    "typescript": "^5.5.0"
  }
}
